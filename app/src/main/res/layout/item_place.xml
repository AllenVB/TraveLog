<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Üst satır: numara | yer adı | checkbox | kamera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Numaralı rozet -->
        <TextView
            android:id="@+id/tvPlaceNumber"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_number_badge"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Yer adı -->
        <TextView
            android:id="@+id/tvPlaceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Gezdim onay kutusu -->
        <CheckBox
            android:id="@+id/checkboxVisited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gezdim"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="8dp" />

        <!-- Fotoğraf ekle (sadece gezdim işaretlenince görünür) -->
        <ImageButton
            android:id="@+id/btnAddPhoto"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_number_badge"
            android:contentDescription="Fotoğraf ekle"
            android:src="@drawable/ic_camera"
            android:padding="6dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Yer fotoğrafı (fotoğraf eklenince görünür) -->
    <ImageView
        android:id="@+id/ivPlacePhoto"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginTop="10dp"
        android:contentDescription="Yer fotoğrafı"
        android:scaleType="centerCrop"
        android:background="@color/image_placeholder"
        android:visibility="gone" />

</LinearLayout>
