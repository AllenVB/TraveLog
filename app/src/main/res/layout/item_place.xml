<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Üst satır: numara | yer adı | checkbox | kamera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Numaralı rozet -->
            <TextView
                android:id="@+id/tvPlaceNumber"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_number_badge"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Yer adı -->
            <TextView
                android:id="@+id/tvPlaceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Gezdim onay kutusu -->
            <CheckBox
                android:id="@+id/checkboxVisited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gezdim"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp" />

            <!-- Fotoğraf ekle (sadece gezdim işaretlenince görünür) -->
            <ImageButton
                android:id="@+id/btnAddPhoto"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_number_badge"
                android:contentDescription="Fotoğraf ekle"
                android:src="@drawable/ic_camera"
                android:padding="7dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Yer fotoğrafı (fotoğraf eklenince görünür) — yuvarlatılmış köşeli kart -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlacePhoto"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivPlacePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Yer fotoğrafı"
                android:scaleType="centerCrop"
                android:background="@color/image_placeholder" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.cardview.widget.CardView>
